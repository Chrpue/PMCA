import random

# Step 1: Generate 30 random floating-point numbers between 20 and 50
random_numbers = [random.uniform(20, 50) for _ in range(30)]

# Step 2: Count how many of these numbers are greater than 30
count_greater_than_30 = sum(1 for number in random_numbers if number > 30)

# Step 3: Print the generated numbers and the count
print("Generated numbers:", random_numbers)
print("Count of numbers greater than 30:", count_greater_than_30)

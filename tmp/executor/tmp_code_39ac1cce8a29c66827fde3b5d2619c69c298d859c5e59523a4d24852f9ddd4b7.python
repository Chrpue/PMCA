import csv

# 定义文件路径
file_path = '/home/chrpue/projects/PMCA/documents/磨溪022-H22.csv'

# 打开并读取 CSV 文件
with open(file_path, mode='r', encoding='utf-8') as file:
    csv_reader = csv.reader(file)
    
    # 读取前几行数据以查看列名和内容
    for i, row in enumerate(csv_reader):
        print(f"Row {i}: {row}")
        if i >= 5:  # 只打印前6行
            break

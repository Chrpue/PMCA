import csv

# 文件路径
file_path = '/home/chrpue/projects/PMCA/documents/磨溪022-H22.csv'

# 打开CSV文件并读取前几行内容
with open(file_path, mode='r', encoding='utf-8') as file:
    reader = csv.reader(file)
    
    # 打印前5行内容
    for i, row in enumerate(reader):
        if i >= 5:
            break
        print(f"行 {i+1}: {row}")

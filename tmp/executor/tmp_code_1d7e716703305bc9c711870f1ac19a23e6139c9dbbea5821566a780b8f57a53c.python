import csv

# 定义文件路径
file_path = '/home/zhaojian/projects/SCADA-Project/Data/磨溪022-H22.csv'

# 打开并读取 CSV 文件
with open(file_path, mode='r', encoding='utf-8') as file:
    csv_reader = csv.DictReader(file)
    
    # 初始化一个列表来存储包含 "物联网关" 的 PID
    iot_gateways = []
    
    # 遍历每一行数据
    for row in csv_reader:
        if '物联网关' in row['DESC']:
            iot_gateways.append(row['PID'])

# 打印结果
print("包含 '物联网关' 的 PID 列表:", iot_gateways)

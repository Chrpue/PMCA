# 已生成的随机数列表
random_numbers = [27.933434997415198, 43.623746307219164, 43.852164277539174, 27.674145842933598, 42.541303595396755, 
                  44.60774831784018, 41.402828141408094, 25.65475172923783, 49.33350697045445, 27.75615890362795, 
                  27.96589496681176, 42.76613751231568, 35.151379653611286, 26.017770301860317, 46.58724671866101, 
                  31.882998989549296, 32.07218995199923, 30.625861190395728, 39.42899228991983, 26.243302044578016, 
                  24.367340404819643, 39.09008238013698, 25.211048654450767, 45.557540496095825, 23.919360041262024, 
                  44.45544935090939, 49.41411515909711, 35.13158720669597, 43.71196676145489, 46.57992837411112]

# 筛选出大于45的数
greater_than_45 = [number for number in random_numbers if number > 45]

# 统计大于45的数的个数
count_greater_than_45 = len(greater_than_45)

# 打印满足条件的数和个数
print("大于45的数:", greater_than_45)
print("大于45的数的个数:", count_greater_than_45)

import csv

file_path = "/home/chrpue/projects/PMCA/documents/磨溪022-H22.csv"
keyword = "物联网关"
pid_list = []

with open(file_path, mode='r', encoding='utf-8-sig') as csvfile:
    csvreader = csv.DictReader(csvfile)
    for row in csvreader:
        if keyword in row['DESC']:
            pid_list.append(row['PID'])

print("符合条件的PID列表:", pid_list)

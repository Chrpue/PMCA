import pandas as pd

# 读取CSV文件
file_path = '/home/chrpue/projects/PMCA/documents/well_data.csv'
df = pd.read_csv(file_path)

# 搜索包含'磨溪022-H22'井描述且包含'物联网关'的行
filtered_df = df[(df['well_description'].str.contains('磨溪022-H22', na=False)) & 
                 (df['device_name'].str.contains('物联网关', na=False))]

# 提取PID列
pids = filtered_df['pid']

# 输出结果
print("包含'磨溪022-H22'井描述且包含'物联网关'的设备的PID:")
print(pids.tolist())

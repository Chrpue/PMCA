import csv

# 打开CSV文件
with open("/home/chrpue/projects/PMCA/documents/高石001-X7.csv", newline='', encoding='utf-8') as csvfile:
    reader = csv.reader(csvfile)
    
    # 读取列名
    columns = next(reader)
    print("Columns:", columns)
    
    # 打印前5行的数据
    print("Sample data:")
    for i, row in enumerate(reader):
        if i < 5:
            print(row)
        else:
            break

import pandas as pd

# 读取CSV文件
file_path = '/home/chrpue/projects/PMCA/documents/磨溪022-H22.csv'
df = pd.read_csv(file_path)

# 筛选包含“物联网关”描述的行
filtered_df = df[df['设备描述'].str.contains('物联网关', na=False)]

# 提取PID列生成列表
pid_list = filtered_df['PID'].tolist()

# 打印结果
print("包含“物联网关”描述的设备的PID列表:")
print(pid_list)

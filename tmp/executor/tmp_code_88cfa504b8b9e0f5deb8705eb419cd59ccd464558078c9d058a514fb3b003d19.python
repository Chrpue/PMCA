import pandas as pd

# 指定文件路径
file_path = '/home/chrpue/projects/PMCA/documents/高石001-X7.csv'

try:
    # 读取CSV文件的前几行（默认是前5行）
    df = pd.read_csv(file_path, nrows=5)
    
    # 显示数据框的内容
    print(df)
except FileNotFoundError:
    print("文件未找到，请检查路径或上传文件。")
except Exception as e:
    print(f"读取文件时出错: {e}")

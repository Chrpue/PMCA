import csv

# 定义文件路径
file_path = "/home/chrpue/projects/PMCA/documents/磨溪022-H22.csv"

# 初始化PID列表
pid_list = []

# 打开并读取CSV文件
with open(file_path, mode='r', encoding='utf-8') as csvfile:
    # 创建CSV阅读器
    csvreader = csv.DictReader(csvfile)
    
    # 遍历每一行
    for row in csvreader:
        # 检查描述字段中是否包含“物联网关”
        if '物联网关' in row['描述']:
            # 提取PID并添加到列表中
            pid_list.append(row['PID'])

# 打印结果
print("符合条件的设备PID列表:", pid_list)

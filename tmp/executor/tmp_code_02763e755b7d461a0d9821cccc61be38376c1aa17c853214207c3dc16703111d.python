import random

# 生成30个20到50之间的浮点数
random_numbers = [random.uniform(20, 50) for _ in range(30)]

# 统计大于30的数值个数
count_greater_than_30 = sum(1 for number in random_numbers if number > 30)

# 输出结果
print("生成的浮点数:", random_numbers)
print("大于30的数值个数:", count_greater_than_30)

# 输出所有大于30的数值
numbers_greater_than_30 = [number for number in random_numbers if number > 30]
print("大于30的浮点数:", numbers_greater_than_30)

import random
import matplotlib.pyplot as plt

# 生成30个在20到50之间的随机浮点数
random_floats = [random.uniform(20, 50) for _ in range(30)]

# 使用直方图可视化这些数据
plt.hist(random_floats, bins=10, edgecolor='black')
plt.title('Histogram of Random Floats')
plt.xlabel('Value')
plt.ylabel('Frequency')
plt.grid(axis='y', alpha=0.75)

# 保存直方图为PNG文件
plt.savefig('random_floats_histogram.png')

# 显示直方图
plt.show()

# 输出生成的随机浮点数
print("Generated Random Floats:", random_floats)

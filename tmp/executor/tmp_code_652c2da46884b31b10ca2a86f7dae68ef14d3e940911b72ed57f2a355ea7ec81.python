import random

# 第一步：生成30个在20到50之间的浮点型数据
data = [random.uniform(20, 50) for _ in range(30)]

# 第二步：创建直方图的频率分布
histogram = {}
for value in data:
    # 将每个浮点数限定到10个桶
    bucket = int((value - 20) // 3)
    histogram[bucket] = histogram.get(bucket, 0) + 1

# 第三步：打印直方图
print("Histogram of Random Floating Points:")
for bucket in range(10):
    count = histogram.get(bucket, 0)
    print(f"{20 + bucket * 3:.1f} - {23 + bucket * 3:.1f}: {'*' * count} ({count})")

import csv

# 定义文件路径
file_path = '/home/chrpue/projects/PMCA/documents/磨溪022-H22.csv'

# 初始化一个列表来存储 PID
pid_list = []

# 打开并读取 CSV 文件
with open(file_path, mode='r', encoding='utf-8') as file:
    csv_reader = csv.DictReader(file)
    
    # 遍历每一行，查找包含 '物联网关' 的行，并提取 PID
    for row in csv_reader:
        if '物联网关' in row.values():
            pid_list.append(row['PID'])

# 打印结果
print("包含 '物联网关' 的设备的 PID 列表:", pid_list)

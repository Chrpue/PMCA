import random

# Step 1: Generate 30 random floating-point numbers between 20 and 50
random_numbers = [random.uniform(20, 50) for _ in range(30)]

# Step 2: Count how many numbers are greater than 40
count_greater_than_40 = sum(1 for num in random_numbers if num > 40)

# Step 3: Print the generated list and the count of numbers greater than 40
print("Generated random numbers:", random_numbers)
print("Count of numbers greater than 40:", count_greater_than_40)

import csv

# 文件路径
file_path = '/home/chrpue/projects/PMCA/documents/磨溪022-H22.csv'

# 存储PID的列表
pid_list = []

# 打开CSV文件并读取内容
with open(file_path, mode='r', encoding='utf-8') as file:
    reader = csv.DictReader(file)
    
    # 检查每一行是否包含关键字“物联网关”
    for row in reader:
        if '物联网关' in row['LONGNAME'] or '物联网关' in row['DESC']:
            pid_list.append(row['PID'])

# 输出PID列表
print("包含关键字‘物联网关’的设备的PID列表:")
for pid in pid_list:
    print(pid)

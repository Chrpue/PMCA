import pandas as pd

# 文件路径
file_path = '/home/chrpue/projects/PMCA/documents/监督中心台账.xlsx'

# 读取Excel文件
df = pd.read_excel(file_path)

# 打印“是否突出问题”列的唯一值，用于验证数据分布
print("‘是否突出问题’列的唯一值：", df['是否突出问题'].unique())

# 筛选出“是否突出问题”列为“是”的所有行
filtered_df = df[df['是否突出问题'] == '是']

# 输出筛选结果
if not filtered_df.empty:
    print(filtered_df)
else:
    print("未找到符合条件的数据。")
